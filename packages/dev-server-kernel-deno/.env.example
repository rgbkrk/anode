# Anode Deno Kernel Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# NOTEBOOK CONFIGURATION
# =============================================================================

# Unique identifier for the notebook this kernel serves
# This should match the notebook ID used by the web client
NOTEBOOK_ID=demo-notebook

# Unique identifier for this kernel instance
# Defaults to kernel-{pid} if not set
# KERNEL_ID=my-kernel-1

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Initial sync delay in milliseconds
# Prevents sequence number conflicts when kernel starts
INITIAL_SYNC_DELAY=229

# =============================================================================
# LIVESTORE CONFIGURATION
# =============================================================================

# LiveStore sync server WebSocket URL
# This connects the kernel to the collaborative notebook system
LIVESTORE_SYNC_URL=ws://localhost:8787

# Authentication token for LiveStore sync
# Change this to a secure token in production
AUTH_TOKEN=insecure-token-change-me

# =============================================================================
# AI INTEGRATION
# =============================================================================

# OpenAI API key for real AI responses
# If not set, the kernel will generate mock responses for development
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI organization ID (optional)
# OPENAI_ORG_ID=org-your-organization-id

# OpenAI base URL (optional, for custom deployments)
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# DEVELOPMENT AND DEBUGGING
# =============================================================================

# Enable debug logging
# DEBUG=1

# Custom cache directory for Pyodide packages
# Defaults to ~/.anode/pyodide-cache
# PYODIDE_CACHE_DIR=/custom/cache/path

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Heartbeat interval in milliseconds (default: 30000)
# How often the kernel sends heartbeat events to stay active
# HEARTBEAT_INTERVAL=30000

# Maximum package cache size in MB (default: 1000)
# CACHE_MAX_SIZE=1000

# Maximum package cache age in days (default: 30)
# CACHE_MAX_AGE=30

# =============================================================================
# SECURITY
# =============================================================================

# Enable/disable function calling in AI responses
# AI_FUNCTION_CALLING=true

# =============================================================================
# EXAMPLES
# =============================================================================

# Development setup with OpenAI
# NOTEBOOK_ID=my-dev-notebook
# OPENAI_API_KEY=sk-your-key-here
# DEBUG=1

# Production setup
# NOTEBOOK_ID=production-notebook
# AUTH_TOKEN=your-secure-token-here
# LIVESTORE_SYNC_URL=wss://your-domain.com/sync
# OPENAI_API_KEY=sk-your-production-key

# Team development
# NOTEBOOK_ID=team-notebook-$(whoami)
# KERNEL_ID=kernel-$(whoami)-$(hostname)
# PYODIDE_CACHE_DIR=/shared/cache/pyodide
